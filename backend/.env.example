# FastAPI Configuration
FASTAPI_ENV=development
FASTAPI_PORT=8000
FASTAPI_HOST=0.0.0.0

# CORS Configuration
CORS_ORIGINS=http://localhost:5174,http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE_MB=100
UPLOAD_TIMEOUT_S=60

# DXF Processing Configuration
DEFAULT_TOLERANCE_PERCENT=0.1
MIN_TOLERANCE_MM=0.001
MAX_TOLERANCE_MM=1.0
AREA_FILTER_MIN_PERCENT=0.5
AREA_FILTER_MAX_PERCENT=2.0

# AI Integration (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
AI_JUDGE_TIMEOUT_S=10
GEMINI_VISION_CLEANUP_ENABLED=false
GEMINI_VISION_MIN_CONFIDENCE=0.7
GEMINI_VISION_MAX_CANDIDATES=6

# Logging
LOG_LEVEL=INFO
